{
  "name": "nexos",
  "version": "0.2.0",
  "description": "NexOS — NexLine Studio",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win portable"
  },

  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },

  "dependencies": {
    "electron-updater": "^6.1.0"
  },

  "build": {
    "appId": "com.nexline.nexos",
    "productName": "NexOS",

    "win": {
      "target": "portable"
    },

    "directories": {
      "output": "dist"
    }
  }
}